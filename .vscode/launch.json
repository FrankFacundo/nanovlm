{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NanoVLM: download data (dry run)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.download_data",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--dry-run",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/data",
        "--max-download-gb",
        "${input:downloadLimitGb}",
        "--include",
        "${input:downloadBucket}"
      ]
    },
    {
      "name": "NanoVLM: download data",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.download_data",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/data",
        "--max-download-gb",
        "${input:downloadLimitGb}",
        "--include",
        "${input:downloadBucket}"
      ]
    },
    {
      "name": "NanoVLM: download model weights",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.download_data",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/data",
        "--max-download-gb",
        "0.001",
        "--exclude",
        "text-pretrain",
        "math-pretrain",
        "code-pretrain",
        "reasoning",
        "sft-text",
        "preference-text",
        "rlvr",
        "vlm-pretrain",
        "vlm-sft",
        "vlm-pref",
        "eval",
        "--download-weights"
      ]
    },
    {
      "name": "NanoVLM: train pretrain S1/S2/S3 (text smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.pretrain",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--stage",
        "${input:pretrainStage}",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/text/train.jsonl",
        "--steps",
        "2",
        "--seq-len",
        "64",
        "--batch-size",
        "1",
        "--total-batch-tokens",
        "64",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/pretrain-${input:pretrainStage}",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train midtrain (text smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.midtrain",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--config",
        "${workspaceFolder}/fixtures/debug/configs/midtrain.yaml",
        "--data-root",
        "${workspaceFolder}/fixtures/debug/data",
        "--steps",
        "2",
        "--seq-len",
        "64",
        "--total-batch-tokens",
        "64",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/midtrain",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train vision align (multimodal smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.vision_align",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--init",
        "scratch",
        "--config",
        "${workspaceFolder}/fixtures/debug/configs/vision_align.yaml",
        "--data-root",
        "${workspaceFolder}/fixtures/debug/data",
        "--image-root",
        "${workspaceFolder}/fixtures/debug/images",
        "--steps",
        "2",
        "--seq-len",
        "128",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/vision_align",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train SFT (text smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.sft",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/sft/text.jsonl",
        "--steps",
        "2",
        "--seq-len",
        "64",
        "--thinking-ratio",
        "0.25",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/sft-text",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train SFT (multimodal smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.sft",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--init",
        "scratch",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/vlm/sft.jsonl",
        "--image-root",
        "${workspaceFolder}/fixtures/debug/images",
        "--steps",
        "2",
        "--seq-len",
        "128",
        "--thinking-ratio",
        "0.0",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/sft-multimodal",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train reasoning SFT (text smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.reasoning_sft",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/sft/reasoning.jsonl",
        "--steps",
        "2",
        "--seq-len",
        "96",
        "--thinking-ratio",
        "0.85",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/reasoning_sft",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train preference DPO/MPO (text smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.preference",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--algo",
        "${input:preferenceAlgo}",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/preference/text.jsonl",
        "--steps",
        "2",
        "--max-prompt-len",
        "32",
        "--max-response-len",
        "16",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/preference-${input:preferenceAlgo}",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train RLVR GRPO/DAPO (text smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.rlvr",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--algo",
        "${input:rlvrAlgo}",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/rlvr/math.jsonl",
        "--steps",
        "2",
        "--group-size",
        "2",
        "--max-new-tokens",
        "8",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/rlvr-${input:rlvrAlgo}",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    },
    {
      "name": "NanoVLM: train agentic RL (tool smoke)",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.agent_rl",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "NANOVLM_BASE_DIR": "${workspaceFolder}/runs/local/debug"
      },
      "args": [
        "--tiny",
        "--text-only",
        "--init",
        "scratch",
        "--data",
        "${workspaceFolder}/fixtures/debug/data/rlvr/math.jsonl",
        "--steps",
        "1",
        "--group-size",
        "2",
        "--max-turns",
        "2",
        "--max-new-tokens-per-turn",
        "8",
        "--no-web",
        "--sandbox-root",
        "${workspaceFolder}/runs/local/debug/tool_sandbox",
        "--device-type",
        "${input:deviceType}",
        "--dtype",
        "${input:dtype}",
        "--out-dir",
        "${workspaceFolder}/runs/local/debug/agent_rl",
        "--log-every",
        "1",
        "--save-every",
        "0"
      ]
    }
  ],
  "inputs": [
    {
      "id": "downloadBucket",
      "type": "pickString",
      "description": "Dataset bucket to include",
      "default": "eval",
      "options": [
        "eval",
        "text-pretrain",
        "math-pretrain",
        "code-pretrain",
        "reasoning",
        "sft-text",
        "preference-text",
        "rlvr",
        "vlm-pretrain",
        "vlm-sft",
        "vlm-pref"
      ]
    },
    {
      "id": "downloadLimitGb",
      "type": "promptString",
      "description": "Maximum download size in GB",
      "default": "1"
    },
    {
      "id": "deviceType",
      "type": "pickString",
      "description": "Training device",
      "default": "cpu",
      "options": [
        "cpu",
        "mps",
        "cuda"
      ]
    },
    {
      "id": "dtype",
      "type": "pickString",
      "description": "Torch dtype",
      "default": "float32",
      "options": [
        "float32",
        "bfloat16",
        "float16"
      ]
    },
    {
      "id": "pretrainStage",
      "type": "pickString",
      "description": "Pretraining stage",
      "default": "S1",
      "options": [
        "S1",
        "S2",
        "S3"
      ]
    },
    {
      "id": "preferenceAlgo",
      "type": "pickString",
      "description": "Preference optimization algorithm",
      "default": "dpo",
      "options": [
        "dpo",
        "mpo"
      ]
    },
    {
      "id": "rlvrAlgo",
      "type": "pickString",
      "description": "RLVR algorithm",
      "default": "dapo",
      "options": [
        "dapo",
        "grpo"
      ]
    }
  ]
}
